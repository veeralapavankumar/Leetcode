   "source": [
    "class Solution(object):\n",
    "    def plusOne(self, digits):\n",
    "        combine = int(\"\".join([str(i) for i in digits]))\n",
    "        combine+=1\n",
    "        digits=[int(digit) for digit in str(combine)]\n",
    "        return digits\n",
    "        "
   ]
  }
