   "source": [
    "class Solution(object):\n",
    "    def findMedianSortedArrays(self, nums1, nums2):\n",
    "        nums=nums1+nums2\n",
    "        nums.sort()\n",
    "        k=len(nums)\n",
    "        if k%2==1:\n",
    "            return nums[k//2]\n",
    "        return (nums[k//2] + nums[k//2 - 1])/2.0"
   ]
  }
 ],
