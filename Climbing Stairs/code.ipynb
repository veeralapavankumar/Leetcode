   "source": [
    "class Solution(object):\n",
    "    def climbStairs(self, n):\n",
    "        if n <= 3: return n\n",
    "\n",
    "        prev1 = 3\n",
    "        prev2 = 2\n",
    "        cur=0\n",
    "        for _ in range(3,n):\n",
    "            cur=prev1 + prev2\n",
    "            prev2 = prev1\n",
    "            prev1 = cur\n",
    "        return cur \n",
    "            "
   ]
  }
 ],
