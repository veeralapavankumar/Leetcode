    "class Solution(object):\n",
    "    def isPalindrome(self, x):\n",
    "        if x<0:\n",
    "            return False\n",
    "        return str(x)== str(x)[::-1]\n",
    "sol = Solution()\n",
    "result = sol.isPalindrome(121)  \n",
    "print(result) "
   ]
  }
