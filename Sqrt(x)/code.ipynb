    "class Solution(object):\n",
    "    def mySqrt(self, x):\n",
    "        if x < 2:\n",
    "            return x\n",
    "        r = x\n",
    "        while r * r > x:\n",
    "        \n",
    "            r = (r + x // r) // 2\n",
    "        return r\n",
    "        "
   ]
