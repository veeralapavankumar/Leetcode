   "source": [
    "class Solution(object):\n",
    "    def reverse(self, x):\n",
    "        sign=-1 if x < 0 else 1\n",
    "        rev = int(str(abs(x))[::-1]) * sign\n",
    "\n",
    "        return rev if -2**31 <= rev <= 2**31 - 1 else 0"
   ]
  }
 ],
