   "source": [
    "class Solution(object):\n",
    "    def minimumTotal(self, triangle):\n",
    "        dp = triangle[-1][:]\n",
    "        for i in range(len(triangle) - 2, -1, -1):\n",
    "            for j in range(len(triangle[i])):\n",
    "                dp[j] = triangle[i][j] + min(dp[j], dp[j + 1])\n",
    "        return dp[0]"
   ]
  }
