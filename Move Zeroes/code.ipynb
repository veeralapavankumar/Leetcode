    "class Solution(object):\n",
    "    def moveZeroes(self, nums):\n",
    "        k=0\n",
    "        for i in range(len(nums)):\n",
    "            if nums[i] !=0:\n",
    "                nums[i],nums[k]=nums[k],nums[i]\n",
    "                k+=1\n",
    "            "
