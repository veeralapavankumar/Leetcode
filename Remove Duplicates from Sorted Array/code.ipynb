   "source": [
    "class Solution(object):\n",
    "    def removeDuplicates(self, nums):\n",
    "        i=1\n",
    "        for j in range(1,len(nums)):\n",
    "            if nums[j] != nums[i-1]:\n",
    "                nums[i] = nums[j]\n",
    "                i+=1\n",
    "        return i"
   ]
  }
